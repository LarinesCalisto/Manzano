Algoritmo "L04H"
// Disciplina  : [Lógica de Programaçăo]
// Professor   : Jailson
// Descriçăo   : Elaborar um programa que possibilite calcular a área total de uma residęncia (sala, cozinha,
//banheiro, quartos, área de serviço, quintal, garagem, etc.). O programa deve solicitar a entrada do
//nome, a largura e o comprimento de um determinado cômodo. Em seguida, deve apresentar a área
//do cômodo lido e também uma mensagem solicitando do usuário a confirmaçăo de continuar
//calculando novos cômodos. Caso o usuário responda “NAO”, o programa deve apresentar o valor
//total acumulado da área residencial.
// Autor(a)    : Larissa Inęs
// Data atual  : 20/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
nome: caractere
largura, comprimento, area, total: real
resp: caractere

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreval("=== AREA DA CASA ===")
total <- 0
   repita
      escreva("Nome do comodo: ")
      leia(nome)

      escreva("Largura: ")
      leia(largura)

      escreva("Comprimento: ")
      leia(comprimento)

      area <- largura * comprimento
      total <- total + area

      escreval("Area: ", area)

      escreva("Deseja continuar? (SIM/NAO): ")
      leia(resp)
   ate resp = "NAO"

   escreval("Area total: ", total)

Fimalgoritmo