Algoritmo "L01H"
// Disciplina   : [ Lógica de Programaçăo]
// Professor   : jaja
// Descriçăo   : Elaborar um programa que calcule e apresente o volume de uma caixa retangular, por meio da fórmula
//VOLUME  COMPRIMENTO * LARGURA * ALTURA.
// Autor(a)    : Larissa
// Data atual  : 17/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
comp, larg, alt, volume: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Comprimento")
leia(comp)
escreva("Largura")
leia(Larg)
escreva("Altura")
leia(alt)
volume <- comp * larg * alt
escreva("Volume: ", volume)

Fimalgoritmo